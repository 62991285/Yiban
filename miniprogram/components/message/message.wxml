<view class="message {{speaker === 'ai' ? 'ai-message' : 'user-message'}}">
  <view class="content">
    <slot></slot>

    <!-- AI 消息才显示选项 -->
    <view wx:if="{{speaker === 'ai' && options && options.length > 0}}" class="options">
      <view
        wx:for="{{options}}"
        wx:key="*this"
        class="option"
        bindtap="onOptionTap"
        data-option="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>
</view>