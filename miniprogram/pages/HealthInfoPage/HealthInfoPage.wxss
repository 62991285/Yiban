/* pages/HealthInfoPage/HealthInfoPage.wxss */
.health-page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  padding: 0 30rpx;
  height: 100rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-btn, .edit-btn {
  font-size: 28rpx;
  color: #fff;
  padding: 10rpx 20rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.info-list {
  padding: 0 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #666;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  text-align: right;
  word-break: break-all;
  padding-left: 20rpx;
}

/* 提示信息 */
.tips {
  padding: 40rpx 30rpx;
  text-align: center;
}

.tips-text {
  font-size: 26rpx;
  color: #999;
}
