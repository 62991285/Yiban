.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F9F1 0%, #F5F5F5 100%);
  padding: 20rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 步骤指示器 */
.steps-indicator {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.step-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F0F0F0;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s;
}

.step-item.active .step-circle {
  background: linear-gradient(135deg, #00C853 0%, #00E676 100%);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 200, 83, 0.3);
}

.step-item.completed .step-circle {
  background: #00C853;
  color: white;
}

.step-text {
  font-size: 22rpx;
  color: #999;
  transition: all 0.3s;
}

.step-item.active .step-text {
  color: #00C853;
  font-weight: bold;
}

.step-line {
  width: 60rpx;
  height: 2rpx;
  background: #F0F0F0;
  margin: 0 10rpx;
}

.step-line.active {
  background: linear-gradient(90deg, #00C853 0%, #00E676 100%);
}

/* 内容卡片 */
.section-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.section-subtitle {
  margin-left: auto;
  font-size: 26rpx;
  color: #00C853;
  background: #E8F5E9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 院区网格 */
.area-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.area-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.3s;
}

.area-item.selected {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #00C853;
}

.area-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.area-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  text-align: center;
}

.area-address {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.selected-mark {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #00C853;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* 科室网格 */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.dept-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.dept-item.selected {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #00C853;
}

.dept-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.dept-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.dept-item.selected .dept-name {
  color: #00C853;
  font-weight: bold;
}

/* 子科室列表 */
.sub-dept-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sub-dept-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.sub-dept-item.selected {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #00C853;
}

.sub-dept-info {
  flex: 1;
}

.sub-dept-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.sub-dept-desc {
  font-size: 24rpx;
  color: #999;
}

.sub-dept-item.selected .sub-dept-name {
  color: #00C853;
}

.check-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #00C853;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 返回按钮 */
.back-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #F0F0F0;
  border-radius: 20rpx;
}

.back-icon {
  font-size: 28rpx;
  color: #666;
  margin-right: 4rpx;
}

.back-text {
  font-size: 24rpx;
  color: #666;
}

/* 日期显示 */
.date-display {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.date-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.date-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #00C853;
}

/* 时段列表 */
.time-slot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-slot-item {
  background: #F8F8F8;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.time-slot-item.selected {
  border-color: #00C853;
}

.slot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.slot-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.time-slot-item.selected .slot-name {
  color: #00C853;
}

.slot-count {
  font-size: 24rpx;
  color: #999;
}

/* 时段网格 */
.period-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 0 24rpx 24rpx;
}

.period-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: white;
  border-radius: 10rpx;
  border: 2rpx solid #E8E8E8;
  transition: all 0.3s;
}

.period-item.selected {
  background: linear-gradient(135deg, #00C853 0%, #00E676 100%);
  border-color: #00C853;
}

.period-time {
  font-size: 26rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.period-item.selected .period-time {
  color: white;
}

.period-status {
  font-size: 20rpx;
  color: #00C853;
}

.period-item.selected .period-status {
  color: rgba(255, 255, 255, 0.9);
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
}

.info-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info-icon {
  font-size: 36rpx;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
  display: block;
}

.info-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
}

/* 提示框 */
.tip-box {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  margin-top: 24rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

/* 空提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-prev,
.btn-next,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-prev {
  background: #F5F5F5;
  color: #666;
}

.btn-prev::after,
.btn-next::after,
.btn-confirm::after {
  border: none;
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.btn-next {
  background: linear-gradient(135deg, #00C853 0%, #00E676 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 200, 83, 0.3);
}

.btn-confirm {
  background: linear-gradient(135deg, #00C853 0%, #00E676 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 200, 83, 0.3);
  flex: 2;
}

.btn-prev:active,
.btn-next:active,
.btn-confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}
