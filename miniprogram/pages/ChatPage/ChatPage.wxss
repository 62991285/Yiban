.ai-dialogue-page {
  width: 100%;
  height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
  position: relative;
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  overflow: hidden;
}

/* AI 智能状态栏 */
.ai-status-bar {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
  position: relative;
  z-index: 100;
}

.ai-status-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #fff;
  opacity: 0.4;
}

.status-dot.active {
  opacity: 1;
  animation: pulse-status 2s ease-in-out infinite;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.8);
}

.status-text {
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.session-info {
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.session-count {
  color: white;
  font-size: 18rpx;
  font-weight: 500;
}

/* 问诊任务描述区 */
.task-description-bar {
  background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #dcfce7;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 粘滞顶部任务描述区 */
.sticky-top {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #ffffff;
  border-bottom: 1px solid #e0e0e0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.stage-summary {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  height: auto;
  min-height: 56rpx;
}

.task-icon {
  font-size: 24rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  color: #22c55e;
  flex-shrink: 0;
}

.task-text {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-word;
}

.toggle-task {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #22c55e;
  cursor: pointer;
  font-weight: bold;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(34, 197, 94, 0.1);
  height: 36rpx;
  line-height: 36rpx;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.toggle-task:active {
  transform: scale(0.95);
  background: rgba(34, 197, 94, 0.2);
}

/* 进度条样式 */
.progress-bar-container {
  margin: 12rpx 0;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #dcfce7;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e, #16a34a);
  border-radius: 4rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 8rpx rgba(34, 197, 94, 0.4);
}

.progress-text {
  font-size: 18rpx;
  color: #22c55e;
  font-weight: 600;
  min-width: 60rpx;
}

.task-detail {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-left: 4px solid #22c55e;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.6;
  background: #f9fafb;
  border-radius: 8rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.task-detail-icon {
  font-size: 24rpx;
  line-height: 1.6;
  flex-shrink: 0;
  color: #22c55e;
}

.task-detail-text {
  flex: 1;
  line-height: 1.6;
  color: #374151;
}

/* 聊天区 */
.chat-history {
  flex: 1;
  padding: 0;
  overflow-y: auto;
  background: transparent;
}

/* 聊天容器 */
.chat-container {
  padding: 24rpx;
  min-height: calc(100vh - 320rpx);
  display: flex;
  flex-direction: column;
}

.message-wrapper {
  margin-bottom: 24rpx;
}

.system-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
}

.system-message {
  font-size: 22rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

.ai-wrapper {
  display: flex;
  justify-content: flex-start;
}

.user-wrapper {
  display: flex;
  justify-content: flex-end;
}

.message-content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 92%;
}

/* 消息图片样式 */
.message-image {
  width: 100%;
  height: auto;
  max-height: 400rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  display: block;
}

/* 消息导航按钮 */
.message-navigations {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  margin-left: 24rpx;
}

.nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f3f4f6;
  border: 1px solid #e5e7eb;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.nav-btn:active {
  background: #e5e7eb;
  transform: translateY(-2rpx) scale(0.96);
}

.nav-icon {
  font-size: 20rpx;
  line-height: 1;
  color: #22c55e;
}

.nav-text {
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

/* 调试信息 */
.debug-info {
  font-size: 18rpx;
  color: #999;
  padding: 4rpx 8rpx;
  margin-top: 8rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 8rpx;
}

/* 消息气泡增强 */
.content {
  max-width: 88%;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  position: relative;
  word-wrap: break-word;
  line-height: 1.6;
  font-size: 28rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.user-wrapper .content {
  max-width: 90%;
}

/* AI 内容 */
.ai-message .content {
  background: #ffffff;
  border-bottom-left-radius: 8rpx;
  margin-left: 24rpx;
  border: 1px solid #e5e7eb;
  color: #374151;
}

/* 用户内容 */
.user-message .content {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
  margin-right: 24rpx;
}

.text {
  font-size: 26rpx;
  line-height: 1.6;
  display: block;
}

.user-message .text {
  color: #ffffff;
}

.options {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option {
  padding: 12rpx 24rpx;
  background: #f3f4f6;
  border: 1px solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #374151;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 500;
}

.option:active {
  transform: translateY(-2rpx) scale(0.96);
  background: #e5e7eb;
}

.option-hover {
  background: #e5e7eb !important;
  transform: translateY(-1rpx);
}

/* ======== AI 风格输入框容器 ======== */
.ai-input-container {
  position: relative;
  background: #ffffff;
  border-top: 1px solid #e5e7eb;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
  z-index: 10;
}

/* 粘滞输入框 */
.sticky-input {
  position: sticky;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #ffffff;
  border-top: 1px solid #e5e7eb;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.input-wrapper-modern {
  position: relative;
  margin: 24rpx 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  border: 1px solid #e5e7eb;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.input-wrapper-modern:focus-within {
  border-color: #22c55e;
  box-shadow: 0 4px 12px rgba(34, 197, 94, 0.15);
}

.input-icon {
  position: absolute;
  left: 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  z-index: 2;
}

.modern-input-box {
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  max-height: 180rpx;
  background: transparent;
  padding: 0 140rpx 0 60rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 76rpx;
  color: #374151;
  display: block;
  vertical-align: middle;
}

.input-wrapper-modern .modern-send-btn {
  position: absolute !important;
  right: 12rpx !important;
  bottom: 12rpx !important;
  width: auto !important;
  height: 56rpx !important;
  padding: 0 24rpx !important;
  background: #e5e7eb !important;
  color: #22c55e !important;
  font-size: 26rpx !important;
  border-radius: 8rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: all 0.3s ease !important;
  border: none !important;
  min-width: 88rpx !important;
}

.modern-send-btn::after {
  border: none;
}

.modern-send-btn.send-btn-active {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%) !important;
  color: white !important;
  box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
}

.modern-send-btn:disabled {
  background: #f3f4f6;
  color: #9ca3af;
  box-shadow: none;
}

.send-text-modern {
  font-size: 24rpx !important;
  font-weight: 500;
}

/* 外部字符计数 */
.outside-char-count {
  position: absolute;
  right: 50rpx;
  bottom: 100rpx;
  z-index: 5;
}

.char-count-modern {
  font-size: 18rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

/* 聊天控制区 */
.chat-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1px solid #e5e7eb;
  position: relative;
  z-index: 20;
  height: 72rpx;
}

/* 粘滞聊天控制区 */
.sticky-controls {
  position: sticky;
  top: 140rpx;
  left: 0;
  right: 0;
  z-index: 90;
  background: #ffffff;
  border-bottom: 1px solid #e5e7eb;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.control-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-chat-history {
  text-align: center;
  color: #dc2626;
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background: #fee2e2;
  border: 1px solid #fecaca;
  cursor: pointer;
  transition: all 0.2s ease;
  font-weight: 500;
}

.delete-chat-history:active {
  background: #fecaca;
}

.chat-stats {
  display: flex;
}

.message-count {
  font-size: 20rpx;
  color: #22c55e;
  background: #f0fdf4;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* ======== 粘滞浮动按钮 ======== */
.sticky-fab-btn {
  position: sticky;
  float: right;
  margin-top: -8rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  z-index: 30;
  cursor: pointer;
  transition: all 0.3s ease;
  right: 24rpx;
}

.sticky-fab-btn:active {
  transform: scale(0.95);
}

.sticky-fab-btn.mode-add {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
}

.sticky-fab-btn.mode-delete {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
}

.fab-icon-new {
  font-size: 32rpx;
  line-height: 1;
}

.fab-tooltip-new {
  position: absolute;
  right: 90rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #1f2937;
  color: white;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
  font-weight: 500;
}

.sticky-fab-btn:active .fab-tooltip-new {
  opacity: 1;
  transform: translateY(-50%) translateX(-4rpx);
}

/* AI 正在输入指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #22c55e;
  animation: typing-bounce 1.4s ease-in-out infinite both;
}

.dot-1 {
  animation-delay: -0.32s;
}
.dot-2 {
  animation-delay: -0.16s;
}
.dot-3 {
  animation-delay: 0s;
}

.typing-text {
  font-size: 24rpx;
  color: #22c55e;
  font-weight: 500;
}

/* 动画效果 */
@keyframes slide-in {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes typing-bounce {
  0%,
  80%,
  100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  40% {
    transform: scale(1.2);
    opacity: 1;
  }
}

.animated-message {
  animation: slide-in 0.4s ease;
}

/* 滚动条美化 - 使用 scroll-view 组件的样式 */
.chat-history {
  /* 隐藏默认滚动条 */
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.chat-history::-webkit-scrollbar {
  display: none;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .modern-input-box {
    padding: 16rpx 120rpx 16rpx 56rpx;
    font-size: 28rpx;
  }

  .modern-send-btn {
    width: 80rpx;
    height: 56rpx;
    right: 8rpx;
    bottom: 8rpx;
  }

  .sticky-fab-btn {
    width: 68rpx;
    height: 68rpx;
    font-size: 34rpx;
    right: 24rpx;
  }
}
