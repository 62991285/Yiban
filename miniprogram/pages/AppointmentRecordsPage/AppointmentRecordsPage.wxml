<view class="container">
  




  <!-- 预约记录列表 -->
  <view class="records-list" wx:if="{{!isEmpty}}">
    <view class="record-card" wx:for="{{records}}" wx:key="id">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="header-main">
          <view class="status-badge {{item.status === '已预约' ? 'active' : 'cancelled'}}">
            <view class="status-dot"></view>
            <text class="status-text">{{item.status}}</text>
          </view>
          <text class="booking-no">预约编号：{{item.bookingNo}}</text>
        </view>
        <text class="booking-date">{{item.date}}</text>
      </view>

      <!-- 卡片内容 -->
      <view class="card-body">
        <view class="info-row">
          <view class="info-icon-box" style="background: #E3F2FD;">
            <text style="color: #2196F3;">🏥</text>
          </view>
          <view class="info-detail">
            <text class="info-label">就诊院区</text>
            <text class="info-value">{{item.area.name}}</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-icon-box" style="background: #F3E5F5;">
            <text style="color: #9C27B0;">🩺</text>
          </view>
          <view class="info-detail">
            <text class="info-label">就诊科室</text>
            <text class="info-value">{{item.department.name}} - {{item.subDepartment.name}}</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-icon-box" style="background: #FFF3E0;">
            <text style="color: #FF9800;">⏰</text>
          </view>
          <view class="info-detail">
            <text class="info-label">就诊时间</text>
            <text class="info-value highlight">{{item.timeSlot.name}} {{item.period.name}}</text>
          </view>
        </view>
      </view>

      <!-- 取消信息 -->
      <view class="cancel-info" wx:if="{{item.cancelTime}}">
        <text class="cancel-icon">ⓘ</text>
        <text class="cancel-text">取消时间：{{item.cancelTime}}</text>
      </view>

      <!-- 卡片操作 -->
      <view class="card-actions">
        <view class="action-btn secondary" bindtap="viewDetail" data-index="{{index}}">
          <text class="action-icon">👁</text>
          <text class="action-text">详情</text>
        </view>
        <view class="action-btn primary" wx:if="{{item.status === '已预约'}}" bindtap="cancelBooking" data-index="{{index}}">
          <text class="action-icon">✕</text>
          <text class="action-text">取消预约</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部添加按钮 -->
  <view class="fab-button" wx:if="{{!isEmpty}}" bindtap="goToBooking">
    <text class="fab-icon">+</text>
    <text class="fab-text">新建预约</text>
  </view>
</view>
