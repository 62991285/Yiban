<!--pages/UtilitiesPage/UtilitiesPage.wxml-->
<view class="container">
  <view class="top-nav">
    <view class="top-nav-title-row">
      <text class="hospital-title">同济医院</text>
      <view class="top-nav-actions">
        <view class="dot-btn">...</view>
      </view>
    </view>

    <view class="search-bar">
      <text class="search-icon">⌕</text>
      <text class="search-placeholder">搜索你需要的服务</text>
    </view>
  </view>

  <!-- 功能网格 -->
  <view class="grid-container">
    <view
      class="grid-item"
      wx:for="{{functionList}}"
      wx:key="id"
      bindtap="navigateToPage"
      data-url="{{item.url}}"
    >
      <view class="icon-wrapper">
        <image class="icon" src="{{item.icon}}" mode="aspectFit"></image>
      </view>
      <text class="item-title">{{item.title}}</text>
      <text class="item-desc">{{item.desc}}</text>
    </view>
  </view>
</view>
