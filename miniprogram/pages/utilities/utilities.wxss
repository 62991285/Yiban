/* pages/utilities/utilities.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #00C853 0%, #69F0AE 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 顶部标题区 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 网格容器 */
.grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 0 10rpx;
}

/* 功能项卡片 */
.grid-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 200, 83, 0.15);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.grid-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #00C853, #69F0AE);
}

.grid-item:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 200, 83, 0.2);
}

/* 图标容器 */
.icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00C853, #69F0AE);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 200, 83, 0.25);
}

.icon {
  width: 60rpx;
  height: 60rpx;
  filter: brightness(0) invert(1);
}

/* 标题 */
.item-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  text-align: center;
  word-break: break-all;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 描述 */
.item-desc {
  font-size: 20rpx;
  color: #999999;
  text-align: center;
  word-break: break-all;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
