/* pages/UserInfoPage/UserInfoPage.wxss */
.mine-page {
  background-color: #f5f7fa;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 卡片样式 */
.section-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 卡片头部 - 绿色主题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 30rpx 30rpx;
  border-bottom: 1px solid #e5e7eb;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
}

.edit-btn {
  font-size: 28rpx;
  color: #ffffff;
  padding: 8rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
}

.edit-btn:active {
  background-color: rgba(255, 255, 255, 0.3);
}

/* 信息列表 */
.info-list {
  padding: 0 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1px solid #f3f4f6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6b7280;
  flex-shrink: 0;
  width: 160rpx;
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: #1f2937;
  flex: 1;
  text-align: right;
  word-break: break-all;
  padding-left: 20rpx;
  font-weight: 500;
}

/* 功能菜单 */
.menu-list {
  padding: 0 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1px solid #f3f4f6;
  transition: all 0.3s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9fafb;
}

.menu-item-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  color: #22c55e;
}

.menu-text {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}
